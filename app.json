{
  "expo": {
    "name": "Mboa Connect",
    "slug": "mboa-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#157347"
    },
    "android": {
      "package": "cm.mboaconnect.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#157347"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "CAMERA", "READ_EXTERNAL_STORAGE"],
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "extra": {
      "apiUrl": "http://10.0.2.2:3000/api/v1",
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
