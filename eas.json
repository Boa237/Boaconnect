{
  "cli": {
    "version": ">= 5.9.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://your-staging-api.example.com/api/v1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_URL": "https://api.mboaconnect.cm/api/v1"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
